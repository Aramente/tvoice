# Tvoice configuration — copy to .env or use ~/.tvoice/config.json
TVOICE_PORT=3000
TVOICE_HOST=127.0.0.1

# Tunnel backend: cloudflare | tailscale | none
TVOICE_TUNNEL=cloudflare

# JWT secret (auto-generated if missing)
# TVOICE_JWT_SECRET=

# Optional persistent password (bcrypt hash)
# TVOICE_PASSWORD_HASH=

# VAPID keys for Web Push (auto-generated if missing)
# TVOICE_VAPID_PUBLIC=
# TVOICE_VAPID_PRIVATE=
# TVOICE_VAPID_SUBJECT=mailto:you@example.com

# tmux session name prefix
TVOICE_TMUX_PREFIX=tvoice

# Ring buffer size per session (KB)
TVOICE_BUFFER_KB=256
