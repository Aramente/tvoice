{
  "name": "tvoice",
  "version": "0.1.6",
  "description": "Mobile-first PWA terminal for steering AI coding agents from your phone. One command, a QR code, and your phone becomes the command center for Claude Code.",
  "type": "module",
  "bin": {
    "tvoice": "bin/tvoice.js"
  },
  "main": "./src/server/index.js",
  "files": [
    "bin",
    "src",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/tvoice.js",
    "dev": "node bin/tvoice.js --no-tunnel",
    "postinstall": "node scripts/fix-node-pty-perms.js",
    "generate-vapid": "node scripts/generate-vapid.js",
    "test": "node --test tests/*.test.js"
  },
  "keywords": [
    "terminal",
    "mobile",
    "pwa",
    "claude-code",
    "ai-agents",
    "tmux",
    "xterm",
    "remote",
    "cloudflare-tunnel"
  ],
  "author": "Kevin Duchier",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aramente/tvoice.git"
  },
  "homepage": "https://github.com/Aramente/tvoice#readme",
  "bugs": {
    "url": "https://github.com/Aramente/tvoice/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "bcryptjs": "^2.4.3",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "cookie": "^1.0.1",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "node-pty": "^1.0.0",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  }
}
